# Site configuration
# Canonical URL of the deployed site (used for OG tags, sitemap, JSON-LD, CORS origin)
PUBLIC_SITE_URL=https://meuip.adryanfreitas.dev

# Google AdSense — client ID
# Get it at https://adsense.google.com → Account → Account information
# Format: ca-pub-XXXXXXXXXXXXXXXX (the "ca-pub-" prefix is required)
PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# AdSense slot IDs (create 3 ad units in AdSense → Ads → By ad unit)
# Format: numeric ID like "1234567890"
PUBLIC_ADSENSE_SLOT_HERO=
PUBLIC_ADSENSE_SLOT_INARTICLE=
PUBLIC_ADSENSE_SLOT_FOOTER=

# Google Funding Choices (consent management)
# Create a European regulations message in AdSense → Privacy & messaging, then
# copy the publisher ID (e.g. "pub-1234567890123456") from the generated snippet.
# Leave empty to disable the consent banner entirely (no AdSense ads will load).
PUBLIC_FUNDING_CHOICES_ID=

# API endpoints for IP detection
# Each URL's origin is auto-added to the CORS allowlist — keep them in sync with the
# subdomains you actually deployed (or use the localhost defaults for development).
PUBLIC_API_IPV4_URL=https://ipv4.adryanfreitas.dev/api/ip
PUBLIC_API_IPV6_URL=https://ipv6.adryanfreitas.dev/api/ip

# Privacy / DPO contact shown on /politica-de-privacidade
PUBLIC_DPO_EMAIL=privacidade@adryanfreitas.dev

# =====================================================
# ads.txt — EDIT public/ads.txt MANUALLY BEFORE DEPLOY
# =====================================================
# The ads.txt file is static (not generated from env).
# Before going to production, replace "pub-XXXXXXXXXXXXXXXX"
# in public/ads.txt with your real publisher ID.
# See: AdSense → Account → Account information
# =====================================================

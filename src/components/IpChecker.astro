---
import { ADSENSE, API_ENDPOINTS } from '../config';
import AdSlot from './AdSlot.astro';
---

<section
  class="ip-checker relative w-full bg-gradient-to-b from-white via-primary-50/40 to-slate-50"
  aria-labelledby="ip-checker-title"
>
  <div class="mx-auto max-w-5xl px-4 pt-10 pb-6 sm:pt-16 sm:pb-10">
    <div class="text-center mb-8 sm:mb-10">
      <p class="inline-block text-xs font-semibold uppercase tracking-wider text-primary-700 bg-primary-100 rounded-full px-3 py-1">
        Ferramenta gratuita
      </p>
      <h1
        id="ip-checker-title"
        class="mt-3 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-slate-900"
      >
        Qual é o <span class="text-primary-600">meu IP</span>?
      </h1>
      <p class="mt-3 text-base sm:text-lg text-slate-600 max-w-2xl mx-auto">
        Descubra seu endereço IP público (IPv4 e IPv6) em tempo real. Detecção
        rápida, segura e sem armazenar dados.
      </p>
    </div>

    <AdSlot slotId={ADSENSE.slots.hero} format="fluid" />

    <div class="grid gap-4 sm:gap-5 md:grid-cols-3">
      <article
        class="ip-card ip-card--preferred relative col-span-1 md:col-span-3 overflow-hidden rounded-2xl border border-primary-200 bg-gradient-to-br from-primary-600 to-primary-800 p-6 text-white shadow-lg shadow-primary-900/10"
        data-role="preferred"
      >
        <div class="flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-primary-100/90">
            Seu IP preferencial
          </span>
          <span class="ip-badge hidden rounded-full bg-white/15 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-white">
            IPv6
          </span>
        </div>
        <div class="ip-value mt-3 min-h-[2.75rem] flex items-center">
          <span class="ip-skeleton block h-8 w-72 max-w-full rounded-md bg-white/20 skeleton"></span>
          <span class="ip-text hidden font-mono text-2xl sm:text-3xl font-semibold tracking-tight break-all"></span>
        </div>
        <div class="ip-state mt-1 text-xs text-primary-100/80">Carregando…</div>
      </article>

      <article
        class="ip-card group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-primary-300 hover:shadow-md"
        data-endpoint={API_ENDPOINTS.ipv4}
        data-role="ipv4"
      >
        <div class="flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">
            Seu IPv4
          </span>
          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-slate-600">
            v4
          </span>
        </div>
        <div class="ip-value mt-3 min-h-[2.25rem] flex items-center">
          <span class="ip-skeleton block h-7 w-56 max-w-full rounded-md bg-slate-200 skeleton"></span>
          <span class="ip-text hidden font-mono text-lg sm:text-xl font-semibold text-slate-900 break-all"></span>
        </div>
        <div class="ip-state mt-1 text-xs text-slate-500">Carregando…</div>
        <button
          type="button"
          class="ip-copy absolute right-3 top-3 inline-flex items-center gap-1 rounded-md border border-slate-200 bg-white/90 px-2 py-1 text-xs font-medium text-slate-600 opacity-0 transition group-hover:opacity-100 focus:opacity-100 hover:bg-primary-50 hover:text-primary-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
          aria-label="Copiar IPv4"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M8 2a2 2 0 0 0-2 2v1H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V6.414a2 2 0 0 0-.586-1.414l-2.414-2.414A2 2 0 0 014.586 2H8Zm0 2h6v3a1 1 0 0 0 1 1h3v6h-1V7a2 2 0 0 0-2-2H8V4Z" />
          </svg>
          <span>Copiar</span>
        </button>
      </article>

      <article
        class="ip-card group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-primary-300 hover:shadow-md"
        data-endpoint={API_ENDPOINTS.ipv6}
        data-role="ipv6"
      >
        <div class="flex items-center justify-between">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">
            Seu IPv6
          </span>
          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-slate-600">
            v6
          </span>
        </div>
        <div class="ip-value mt-3 min-h-[2.25rem] flex items-center">
          <span class="ip-skeleton block h-7 w-56 max-w-full rounded-md bg-slate-200 skeleton"></span>
          <span class="ip-text hidden font-mono text-lg sm:text-xl font-semibold text-slate-900 break-all"></span>
        </div>
        <div class="ip-state mt-1 text-xs text-slate-500">Carregando…</div>
        <button
          type="button"
          class="ip-copy absolute right-3 top-3 inline-flex items-center gap-1 rounded-md border border-slate-200 bg-white/90 px-2 py-1 text-xs font-medium text-slate-600 opacity-0 transition group-hover:opacity-100 focus:opacity-100 hover:bg-primary-50 hover:text-primary-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
          aria-label="Copiar IPv6"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M8 2a2 2 0 0 0-2 2v1H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V6.414a2 2 0 0 0-.586-1.414l-2.414-2.414A2 2 0 0 014.586 2H8Zm0 2h6v3a1 1 0 0 0 1 1h3v6h-1V7a2 2 0 0 0-2-2H8V4Z" />
          </svg>
          <span>Copiar</span>
        </button>
      </article>

      <article
        class="ip-card relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
        data-role="status"
      >
        <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">
          Status da conexão
        </div>
        <div class="ip-value mt-3 min-h-[2.25rem] flex items-center">
          <span class="ip-skeleton block h-7 w-40 max-w-full rounded-md bg-slate-200 skeleton"></span>
          <span class="ip-text hidden text-base font-medium text-slate-800"></span>
        </div>
        <div class="ip-state mt-1 text-xs text-slate-500">Verificando…</div>
      </article>

      <article
        class="ip-card group relative col-span-1 md:col-span-3 overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
        data-role="hostname"
      >
        <div class="flex items-center justify-between">
          <div class="text-xs font-semibold uppercase tracking-wider text-slate-500">
            Hostname (DNS reverso)
          </div>
          <span class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-slate-600">
            PTR
          </span>
        </div>
        <div class="ip-value mt-3 min-h-[2.25rem] flex items-center">
          <span class="ip-skeleton block h-7 w-72 max-w-full rounded-md bg-slate-200 skeleton"></span>
          <span class="ip-text hidden font-mono text-base sm:text-lg font-medium text-slate-800 break-all"></span>
        </div>
        <div class="ip-state mt-1 text-xs text-slate-500">Resolvendo…</div>
        <button
          type="button"
          class="ip-copy absolute right-3 top-3 inline-flex items-center gap-1 rounded-md border border-slate-200 bg-white/90 px-2 py-1 text-xs font-medium text-slate-600 opacity-0 transition group-hover:opacity-100 focus:opacity-100 hover:bg-primary-50 hover:text-primary-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
          aria-label="Copiar hostname"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M8 2a2 2 0 0 0-2 2v1H5a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-1h1a2 2 0 0 0 2-2V6.414a2 2 0 0 0-.586-1.414l-2.414-2.414A2 2 0 0 014.586 2H8Zm0 2h6v3a1 1 0 0 0 1 1h3v6h-1V7a2 2 0 0 0-2-2H8V4Z" />
          </svg>
          <span>Copiar</span>
        </button>
      </article>
    </div>

    <p class="mt-4 text-center text-xs text-slate-500">
      Detectado diretamente do seu navegador via DNS separado para IPv4 e IPv6.
    </p>
  </div>
</section>

<script>
  type IpResponse = { ip: string; hostname?: string | null };
  type IpRole = 'preferred' | 'ipv4' | 'ipv6' | 'status' | 'hostname';
  type State = 'loading' | 'ready' | 'unavailable' | 'error';

  const IPV4_REGEX = /^(?:\d{1,3}\.){3}\d{1,3}$/;
  const IPV4_MAPPED_PREFIX = '::ffff:';

  function cleanIp(raw: string, role: IpRole): string {
    let ip = raw.trim();
    if (role === 'ipv4' && ip.toLowerCase().startsWith(IPV4_MAPPED_PREFIX)) {
      ip = ip.slice(IPV4_MAPPED_PREFIX.length);
    }
    return ip;
  }

  function isLikelyIpv4(s: string): boolean {
    return IPV4_REGEX.test(s);
  }

  function isLikelyIpv6(s: string): boolean {
    return s.includes(':') && !s.startsWith(IPV4_MAPPED_PREFIX);
  }

  interface CardEls {
    card: HTMLElement;
    skeleton: HTMLElement | null;
    text: HTMLElement | null;
    state: HTMLElement | null;
    copy: HTMLButtonElement | null;
    badge: HTMLElement | null;
  }

  function getCardEls(role: IpRole): CardEls | null {
    const card = document.querySelector<HTMLElement>(`.ip-card[data-role="${role}"]`);
    if (!card) return null;
    return {
      card,
      skeleton: card.querySelector<HTMLElement>('.ip-skeleton'),
      text: card.querySelector<HTMLElement>('.ip-text'),
      state: card.querySelector<HTMLElement>('.ip-state'),
      copy: card.querySelector<HTMLButtonElement>('.ip-copy'),
      badge: card.querySelector<HTMLElement>('.ip-badge'),
    };
  }

  function setState(
    els: CardEls,
    state: State,
    options: { value?: string; message?: string } = {},
  ): void {
    const { skeleton, text, state: stateEl, badge } = els;

    if (skeleton) skeleton.classList.toggle('hidden', state !== 'loading');
    if (text) {
      text.classList.toggle('hidden', state === 'loading' || state === 'error');
      if (state === 'ready' && text && options.value !== undefined) {
        text.textContent = options.value;
        text.classList.remove('hidden');
        text.classList.add('pop');
        setTimeout(() => text.classList.remove('pop'), 200);
      }
    }
    if (stateEl) {
      const messages: Record<State, string> = {
        loading: 'Carregando…',
        ready: 'Detectado ✓',
        unavailable: 'Não disponível na sua conexão',
        error: 'Erro ao detectar — tente novamente',
      };
      stateEl.textContent = options.message ?? messages[state];
      stateEl.classList.toggle('text-emerald-600', state === 'ready');
      stateEl.classList.toggle('text-amber-600', state === 'unavailable');
      stateEl.classList.toggle('text-rose-600', state === 'error');
    }
    if (badge) {
      if (state === 'ready' && options.value && isLikelyIpv6(options.value)) {
        badge.textContent = 'IPv6';
        badge.classList.remove('hidden');
      } else if (state === 'ready' && options.value && isLikelyIpv4(options.value)) {
        badge.textContent = 'IPv4';
        badge.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
      }
    }
  }

  async function fetchIp(url: string, signal: AbortSignal): Promise<string | null> {
    try {
      const res = await fetch(url, {
        method: 'GET',
        signal,
        cache: 'no-store',
        credentials: 'omit',
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) return null;
      const data = (await res.json()) as Partial<IpResponse>;
      if (typeof data.ip !== 'string' || data.ip.length === 0) return null;
      return data.ip;
    } catch {
      return null;
    }
  }

  async function fetchIpWithDetail(
    url: string,
    signal: AbortSignal,
  ): Promise<IpResponse | null> {
    try {
      const res = await fetch(url, {
        method: 'GET',
        signal,
        cache: 'no-store',
        credentials: 'omit',
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) return null;
      const data = (await res.json()) as Partial<IpResponse>;
      if (typeof data.ip !== 'string' || data.ip.length === 0) return null;
      return { ip: data.ip, hostname: data.hostname ?? null };
    } catch {
      return null;
    }
  }

  function attachCopyHandler(els: CardEls, getValue: () => string | null): void {
    if (!els.copy) return;
    const btn = els.copy;
    const label = btn.querySelector('span');

    btn.addEventListener('click', async () => {
      const value = getValue();
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copiado!';
          btn.classList.add('!bg-emerald-50', '!text-emerald-700', '!border-emerald-300');
          setTimeout(() => {
            if (label) label.textContent = original;
            btn.classList.remove('!bg-emerald-50', '!text-emerald-700', '!border-emerald-300');
          }, 1400);
        }
      } catch {
        if (label) label.textContent = 'Falhou';
        setTimeout(() => {
          if (label) label.textContent = 'Copiar';
        }, 1400);
      }
    });
  }

  function init(): void {
    const preferredEls = getCardEls('preferred');
    const ipv4Els = getCardEls('ipv4');
    const ipv6Els = getCardEls('ipv6');
    const statusEls = getCardEls('status');
    const hostnameEls = getCardEls('hostname');

    if (!preferredEls || !ipv4Els || !ipv6Els || !statusEls || !hostnameEls) return;

    const controller = new AbortController();
    const { signal } = controller;

    const endpoints = {
      ipv4: ipv4Els.card.dataset.endpoint ?? '',
      ipv6: ipv6Els.card.dataset.endpoint ?? '',
    };

    setState(preferredEls, 'loading');
    setState(ipv4Els, 'loading');
    setState(ipv6Els, 'loading');
    setState(statusEls, 'loading');
    setState(hostnameEls, 'loading');

    let ipv4Ip: string | null = null;
    let ipv6Ip: string | null = null;

    const updatePreferred = (): void => {
      const preferred = ipv6Ip ?? ipv4Ip;
      if (preferred) {
        setState(preferredEls, 'ready', { value: preferred });
      } else {
        setState(preferredEls, 'error', { message: 'Nenhum IP detectado' });
      }
    };

    const updateStatus = (): void => {
      if (ipv4Ip && ipv6Ip) {
        setState(statusEls, 'ready', { value: 'Dual-stack (IPv4 + IPv6)' });
      } else if (ipv6Ip) {
        setState(statusEls, 'ready', { value: 'Somente IPv6' });
      } else if (ipv4Ip) {
        setState(statusEls, 'ready', { value: 'Somente IPv4' });
      } else {
        setState(statusEls, 'error');
      }
    };

    attachCopyHandler(preferredEls, () => preferredEls.text?.textContent ?? null);
    attachCopyHandler(ipv4Els, () => ipv4Els.text?.textContent ?? null);
    attachCopyHandler(ipv6Els, () => ipv6Els.text?.textContent ?? null);
    attachCopyHandler(hostnameEls, () => hostnameEls.text?.textContent ?? null);

    void (async () => {
      const [v4Raw, v6Raw] = await Promise.all([
        fetchIp(endpoints.ipv4, signal),
        fetchIp(endpoints.ipv6, signal),
      ]);

      if (v4Raw) {
        const value = cleanIp(v4Raw, 'ipv4');
        if (isLikelyIpv4(value)) {
          ipv4Ip = value;
          setState(ipv4Els, 'ready', { value });
        } else {
          setState(ipv4Els, 'unavailable');
        }
      } else {
        setState(ipv4Els, 'unavailable');
      }

      if (v6Raw) {
        const value = cleanIp(v6Raw, 'ipv6');
        if (isLikelyIpv6(value)) {
          ipv6Ip = value;
          setState(ipv6Els, 'ready', { value });
        } else {
          setState(ipv6Els, 'unavailable');
        }
      } else {
        setState(ipv6Els, 'unavailable');
      }

      updatePreferred();
      updateStatus();

      const preferredIp = ipv6Ip ?? ipv4Ip;
      const preferredEndpoint = ipv6Ip ? endpoints.ipv6 : endpoints.ipv4;
      if (preferredIp && preferredEndpoint) {
        const detail = await fetchIpWithDetail(preferredEndpoint, signal);
        const hostname = detail?.hostname;
        if (hostname) {
          setState(hostnameEls, 'ready', { value: hostname });
        } else {
          setState(hostnameEls, 'unavailable', {
            message: 'Sem registro PTR para este IP',
          });
        }
      } else {
        setState(hostnameEls, 'error', { message: 'IP necessário para resolver' });
      }
    })();

    window.addEventListener('beforeunload', () => controller.abort());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
